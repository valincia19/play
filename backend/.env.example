# ═══════════════════════════════════════════════════════════════════════════
# VERCELPLAY BACKEND — Environment Configuration Example
# ═══════════════════════════════════════════════════════════════════════════

# Core Settings
NODE_ENV=development
LOG_LEVEL=debug
PORT=4000

# Server URLs
APP_URL=http://localhost:4000
FRONTEND_URL=http://localhost:5173

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:password@localhost:5432/vercelplay

# Cache & Queue (Redis)
REDIS_URL=redis://localhost:6379

# Security
JWT_SECRET=super-secret-jwt-key-for-development-only-change-in-production
STORAGE_ENCRYPTION_KEY=insert_64_character_hex_string_here_for_development_environment

# Payment Gateway (Pakasir)
PAKASIR_API_KEY=your-pakasir-api-key
PAKASIR_MERCHANT_ID=your-pakasir-merchant-id
PAKASIR_BASE_URL=https://v2-api.pakasir.com

# Webhook Security
WEBHOOK_SECRET=your-shared-webhook-secret

# SMTP (Email Delivery)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@vercelplay.com
SMTP_FROM_NAME=Vercelplay
