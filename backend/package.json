{
  "name": "backend",
  "module": "apps/api/main.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch apps/api/main.ts",
    "dev:worker": "bun run --watch apps/worker/main.ts",
    "start": "bun run apps/api/main.ts",
    "start:worker": "bun run apps/worker/main.ts",
    "test": "bun run test/auth.test.ts",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "audit:security": "npm audit --audit-level=moderate",
    "audit:licenses": "license-checker --production --onlyAllow 'MIT;Apache-2.0;BSD-3-Clause;ISC'",
    "audit:outdated": "npm outdated --json",
    "audit:all": "npm run audit:security && npm run audit:outdated",
    "deps:update": "npm update @aws-sdk/client-s3 @aws-sdk/lib-storage elysia bullmq pino nodemailer && npm run audit:security",
    "deps:check": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/bun": "latest",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/lib-storage": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@elysiajs/cors": "^1.4.1",
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@ffprobe-installer/ffprobe": "^2.1.2",
    "@sinclair/typebox": "^0.34.49",
    "@types/fluent-ffmpeg": "^2.1.28",
    "bcryptjs": "^3.0.2",
    "bullmq": "^5.73.0",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "elysia-rate-limit": "^4.5.1",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.4",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.8"
  }
}
