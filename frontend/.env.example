# VERCELPLAY FRONTEND — Environment Configuration Example
# ═══════════════════════════════════════════════════════════════════════════

# Backend API URL (Mandatory)
VITE_API_BASE_URL=http://localhost:4000

# Application URL
VITE_APP_URL=http://localhost:5173
VITE_FRONTEND_URL=http://localhost:5173

# Domain Configurations (Mandatory for multi-domain routing)
VITE_SHARE_DOMAIN=localhost:5173
VITE_MAIN_DOMAIN=localhost:5173
